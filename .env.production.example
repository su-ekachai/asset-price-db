# QuestDB Connection
QUESTDB_HOST=questdb
QUESTDB_ILP_PORT=9000
QUESTDB_PG_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# Security
QUESTDB_ILP_TLS=
QUESTDB_SSLMODE=disable

# Logging
OHLCV_LOG_FORMAT=json
OHLCV_LOG_FILE=/app/logs/ohlcv.log

# Sync interval (used by scheduler, in seconds)
SYNC_INTERVAL=300
